{
  "$jsonSchema": {
    "bsonType": "object",
    "required": ["name", "alter", "position", "rueckennummer", "gehalt", "geburtsdatum"],
    "properties": {
      "name": {
        "bsonType": "string"
      },
      "alter": {
        "bsonType": "int",
        "minimum": 15,
        "maximum": 45
      },
      "position": {
        "bsonType": "string",
        "enum": ["Tor", "Abwehr", "Mittelfeld", "Stürmer"]
      },
      "rueckennummer": {
        "bsonType": "int",
        "minimum": 1,
        "maximum": 99
      },
      "gehalt": {
        "bsonType": "double",
        "minimum": 0
      },
      "geburtsdatum": {
        "bsonType": "date"
      },
      "mannschaften": {
        "bsonType": "array",
        "items": {
          "bsonType": "object",
          "required": ["mannschaftId", "name"],
          "properties": {
            "mannschaftId": {
              "bsonType": "objectId"
            },
            "name": {
              "bsonType": "string"
            }
          }
        }
      }
    }
  }
}
